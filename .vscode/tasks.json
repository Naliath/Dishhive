{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ng: serve",
      "type": "npm",
      "script": "start",
      "path": "src/dishhive-web/",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Building\\.\\.\\."
          },
          "endsPattern": {
            "regexp": "(Application bundle generation complete|Watch mode enabled)"
          }
        }
      }
    }
  ]
}
