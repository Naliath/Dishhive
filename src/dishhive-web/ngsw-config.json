{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/icon.svg",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/icons/*",
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ],
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-recipe-images",
      "urls": ["/api/recipes/*/image"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 200,
        "maxAge": "7d"
      }
    },
    {
      "name": "api-week-plan",
      "urls": ["/api/plannedmeals**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 60,
        "maxAge": "7d",
        "timeout": "4s"
      }
    },
    {
      "name": "api-shopping-list",
      "urls": ["/api/shoppinglist**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "7d",
        "timeout": "4s"
      }
    },
    {
      "name": "api-reference",
      "urls": [
        "/api/familymembers**",
        "/api/settings**",
        "/api/cookbooks**",
        "/api/recipes**",
        "/api/statistics**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 300,
        "maxAge": "7d",
        "timeout": "4s"
      }
    }
  ]
}
